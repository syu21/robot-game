[Unit]
Description=robot-game portal online count sender
After=network-online.target robot-game.service
Wants=network-online.target

[Service]
Type=oneshot
User=ubuntu
Group=www-data
WorkingDirectory=/home/ubuntu/robot-game
EnvironmentFile=/home/ubuntu/robot-game/.env.production
ExecStart=/home/ubuntu/robot-game/venv/bin/python3 /home/ubuntu/robot-game/send_online_count.py --flush-limit 12

