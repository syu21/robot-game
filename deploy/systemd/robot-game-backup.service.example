[Unit]
Description=robot-game daily backup job
After=robot-game.service

[Service]
Type=oneshot
User=ubuntu
Group=www-data
WorkingDirectory=/home/ubuntu/robot-game
EnvironmentFile=/home/ubuntu/robot-game/.env.production
ExecStart=/home/ubuntu/robot-game/venv/bin/python3 /home/ubuntu/robot-game/manage_backups.py --keep-latest 7

